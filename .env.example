# CRV Studio — Variables de entorno
# NUNCA commitear el .env real. Solo este .env.example.
# Configurar los valores reales en Cloudflare Dashboard → Workers → Settings → Variables

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# GitHub (para CI/CD y acceso a repos de clientes)
GITHUB_TOKEN=ghp_XXXXXXXXXXXXXXXXXXXX

# Cloudflare
CLOUDFLARE_ACCOUNT_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
CLOUDFLARE_API_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Base de datos D1
DB_ID=XXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX

# KV Namespace (rate limiting)
KV_RATE_LIMITS_ID=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email (Resend)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXX

# Seguridad
ADMIN_SECRET=cambiar_por_string_random_seguro
ALLOWED_ORIGIN=https://crv.studio

# Entorno (development | production)
ENVIRONMENT=development
